# ----------------------------------------------------------------------------
# Database — Supabase Postgres
# ----------------------------------------------------------------------------
# From Supabase → Project Settings → Database → Connection string
#   DATABASE_URL: "Transaction pooler" URI (port 6543, pgbouncer=true) for runtime
#   DIRECT_URL:   "Session pooler" or direct (port 5432) URI for migrations
DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ----------------------------------------------------------------------------
# Supabase — Auth + Storage
# ----------------------------------------------------------------------------
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL="https://[project].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service role key — server-only, never expose to the client.
# Used to upload photos + signatures to Storage. Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=""

# ----------------------------------------------------------------------------
# Admin seeding
# ----------------------------------------------------------------------------
# Comma-separated emails that auto-receive ADMIN role on first login
ADMIN_EMAILS="andrew@citrotech.com"

# ----------------------------------------------------------------------------
# Google Maps — added in Phase 4
# ----------------------------------------------------------------------------
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""
GOOGLE_MAPS_API_KEY=""

# ----------------------------------------------------------------------------
# Salesforce — one-way pull of Closed-Won opportunities into CitroTech.
# Optional: leave blank to disable the integration entirely.
# ----------------------------------------------------------------------------
# Required (only when using SF integration):
SALESFORCE_USERNAME=""
SALESFORCE_PASSWORD=""
# Reset via Salesforce → avatar → Settings → Reset My Security Token
# (it arrives by email, 24-char string)
SALESFORCE_SECURITY_TOKEN=""

# Optional:
# Production:  https://login.salesforce.com  (default)
# Sandbox:     https://test.salesforce.com
SALESFORCE_LOGIN_URL=""

# Optional: override the default SOQL query if your SF schema has custom
# fields. The default pulls Closed Won opportunities from the past 24h
# with their Account name, phone, and billing address.
SALESFORCE_SOQL_QUERY=""

# ----------------------------------------------------------------------------
# Cron secret — protects internal cron endpoints (Phase 6)
# ----------------------------------------------------------------------------
CRON_SECRET=""
